# Storj S3 Gateway
STORJ_ACCESS_KEY=
STORJ_SECRET_KEY=
STORJ_ENDPOINT=https://gateway.storjshare.io
STORJ_REGION=eu1
STORJ_BUCKET=dwinity-tax

# Tax-App
TAX_SECRET_KEY=          # python -c "import secrets; print(secrets.token_urlsafe(48))"
TAX_DB_PATH=/opt/dwinity-tax-api/data/tax.db
TAX_BASE_URL=https://app.tax.mkwt-strategy.tech

# Mail (Magic-Link Versand)
TAX_MAIL_FROM=hello@dwinity.de
TAX_MAIL_FROM_NAME=Dwinity Tax
TAX_MAIL_MODE=smtp        # console | smtp
TAX_SMTP_HOST=smtp.hostinger.com
TAX_SMTP_PORT=465
TAX_SMTP_USER=
TAX_SMTP_PASS=
TAX_SMTP_SSL=true

# Etherscan v2 Multichain — https://etherscan.io/myapikey
TAX_ETHERSCAN_KEY=
